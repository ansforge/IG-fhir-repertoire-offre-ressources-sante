       ] [
         fhir:key [ fhir:v "que-5" ] ;
         fhir:severity [ fhir:v "error" ] ;
         fhir:human [ fhir:v "Only 'choice' and 'open-choice' items can have answerValueSet" ] ;
         fhir:expression [ fhir:v "(type ='choice' or type = 'open-choice' or type = 'decimal' or type = 'integer' or type = 'date' or type = 'dateTime' or type = 'time' or type = 'string' or type = 'quantity') or (answerValueSet.empty() and answerOption.empty())" ] ;
         fhir:xpath [ fhir:v "f:type/@value=('choice','open-choice','decimal','integer','date','dateTime','time','string','quantity',') or not(f:answerOption or f:answerValueSet)" ] ;
