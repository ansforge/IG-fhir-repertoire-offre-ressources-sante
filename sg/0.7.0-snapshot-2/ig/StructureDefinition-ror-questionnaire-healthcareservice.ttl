       ] [
         fhir:key [ fhir:v "que-4" ] ;
         fhir:severity [ fhir:v "error" ] ;
         fhir:human [ fhir:v "A question cannot have both answerOption and answerValueSet" ] ;
         fhir:expression [ fhir:v "answerOption.empty() or answerValueSet.empty()" ] ;
         fhir:xpath [ fhir:v "not(f:answerValueSet and f:answerOption)" ] ;
         fhir:source [
           fhir:v "http://hl7.org/fhir/StructureDefinition/Questionnaire"^^xsd:anyURI ;
