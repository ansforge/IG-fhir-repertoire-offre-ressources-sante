         fhir:severity [ fhir:v "error" ] ;
         fhir:human [ fhir:v "Group items must have nested items, display items cannot have nested items" ] ;
         fhir:expression [ fhir:v "(type='group' implies item.empty().not()) and (type.trace('type')='display' implies item.trace('item').empty())" ] ;
         fhir:xpath [ fhir:v "not((f:type/@value='group' and not(f:item)) or (f:type/@value='display' and f:item))" ] ;
         fhir:source [
           fhir:v "http://hl7.org/fhir/StructureDefinition/Questionnaire"^^xsd:anyURI ;
           fhir:link <http://hl7.org/fhir/StructureDefinition/Questionnaire>
         ]
       ] [
         fhir:key [ fhir:v "que-3" ] ;
         fhir:severity [ fhir:v "error" ] ;
         fhir:human [ fhir:v "Display items cannot have a \"code\" asserted" ] ;
         fhir:expression [ fhir:v "type!='display' or code.empty()" ] ;
         fhir:xpath [ fhir:v "not(f:type/@value='display' and f:code)" ] ;
         fhir:source [
           fhir:v "http://hl7.org/fhir/StructureDefinition/Questionnaire"^^xsd:anyURI ;
           fhir:link <http://hl7.org/fhir/StructureDefinition/Questionnaire>
