         fhir:human [ fhir:v "An item cannot have an answerExpression if answerOption or answerValueSet is already present." ] ;
         fhir:expression [ fhir:v "extension('http://hl7.org/fhir/uv/sdc/StructureDefinition/sdc-questionnaire-answerExpression').empty().not() implies (answerOption.empty() and answerValueSet.empty())" ] ;
         fhir:xpath [ fhir:v "f:extension[@url='http://hl7.org/fhir/uv/sdc/StructureDefinition/sdc-questionnaire-answerExpression'] and (not(f:answerOption) and not(f:answerValueSet))" ] ;
         fhir:source [
