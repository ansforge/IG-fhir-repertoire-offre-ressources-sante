         fhir:severity [ fhir:v "error" ] ;
         fhir:human [ fhir:v "Required and repeat aren't permitted for display items" ] ;
         fhir:expression [ fhir:v "type!='display' or (required.empty() and repeats.empty())" ] ;
         fhir:xpath [ fhir:v "not(f:type/@value='display' and (f:required or f:repeats))" ] ;
