       ] [
         fhir:key [ fhir:v "que-11" ] ;
         fhir:severity [ fhir:v "error" ] ;
         fhir:human [ fhir:v "If one or more answerOption is present, initial[x] must be missing" ] ;
         fhir:expression [ fhir:v "answerOption.empty() or initial.empty()" ] ;
         fhir:xpath [ fhir:v "not(f:answerOption) or not(count(f:*[starts-with(local-name(.), 'initial')]))" ] ;
         fhir:source [
           fhir:v "http://hl7.org/fhir/StructureDefinition/Questionnaire"^^xsd:anyURI ;
           fhir:link <http://hl7.org/fhir/StructureDefinition/Questionnaire>
         ]
       ] [
         fhir:key [ fhir:v "que-12" ] ;
         fhir:severity [ fhir:v "error" ] ;
         fhir:human [ fhir:v "If there are more than one enableWhen, enableBehavior must be specified" ] ;
         fhir:expression [ fhir:v "enableWhen.count() > 2 implies enableBehavior.exists()" ] ;
         fhir:xpath [ fhir:v "not(f:answerOption) or not(count(f:*[starts-with(local-name(.), 'initial')]))" ] ;
         fhir:source [
           fhir:v "http://hl7.org/fhir/StructureDefinition/Questionnaire"^^xsd:anyURI ;
           fhir:link <http://hl7.org/fhir/StructureDefinition/Questionnaire>
         ]
       ] [
         fhir:key [ fhir:v "que-13" ] ;
         fhir:severity [ fhir:v "error" ] ;
         fhir:human [ fhir:v "Can only have multiple initial values for repeating items" ] ;
         fhir:expression [ fhir:v "repeats=true or initial.count() <= 1" ] ;
         fhir:xpath [ fhir:v "f:repeats/@value='true' or count(f:initial)<=1" ] ;
