       fhir:constraint ( [
         fhir:key [ fhir:v "ror-inv-1" ] ;
         fhir:severity [ fhir:v "error" ] ;
         fhir:human [ fhir:v "Types must be from the specified value set of resource types based on name ror-structure: Location, HealthcareServive, Organization" ] ;
         fhir:expression [ fhir:v "(extension('name').value.where(code='ror-structure' and system='http://hl7.org/fhir/uv/sdc/CodeSystem/launchContext').exists() implies extension('type').all(value='Location' or value='HealthcareService' or value='Organization'))" ] ;
         fhir:xpath [ fhir:v "(not(f:extension[@url='name' and f:valueCoding[f:code/@value='ror-structure' and f:system/@value='http://hl7.org/fhir/uv/sdc/CodeSystem/launchContext']]) or not(f:extension[@url='type' and f:valueCode/@value!=('Location','HealthcareService','Organization')]))" ] ;
         fhir:source [
           fhir:v "https://interop.esante.gouv.fr/ig/fhir/ror/StructureDefinition/ror-launchcontext"^^xsd:anyURI ;
           fhir:link <https://interop.esante.gouv.fr/ig/fhir/ror/StructureDefinition/ror-launchcontext>
         ]
       ] )
     ] [
       fhir:id [ fhir:v "Extension.extension:name" ] ;
       fhir:path [ fhir:v "Extension.extension" ] ;
       fhir:sliceName [ fhir:v "name" ]
     ] [
       fhir:id [ fhir:v "Extension.extension:name.extension" ] ;
       fhir:path [ fhir:v "Extension.extension.extension" ] ;
       fhir:max [ fhir:v "0" ]
     ] [
       fhir:id [ fhir:v "Extension.extension:name.value[x]" ] ;
       fhir:path [ fhir:v "Extension.extension.value[x]" ] ;
       fhir:binding [
         fhir:strength [ fhir:v "extensible" ] ;
         fhir:valueSet [
           fhir:v "https://interop.esante.gouv.fr/ig/fhir/ror/ValueSet/ror-launch-context-vs"^^xsd:anyURI ;
           fhir:link <https://interop.esante.gouv.fr/ig/fhir/ror/ValueSet/ror-launch-context-vs>
         ]
       ]
     ] )
  ] . # 

